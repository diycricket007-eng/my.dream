function drawParticle(p){
  ctx.globalAlpha=p.life/p.maxLife;
  ctx.fillStyle=p.color;
  ctx.beginPath(); ctx.arc(p.x,p.y,p.size*p.life/p.maxLife,0,Math.PI*2); ctx.fill();
  ctx.globalAlpha=1;
}
function spawnParticles(x,y,color,count,size){
  for(let i=0;i<count;i++){
    const a=Math.random()*Math.PI*2, s=20+Math.random()*65;
    particles.push({x,y,dx:Math.cos(a)*s,dy:Math.sin(a)*s-22,color,size:size||3,life:.6+Math.random()*.4,maxLife:.6+Math.random()*.4});
  }
}
 
// ══════════════════════════════════════
// TERRAIN & CASTLE
// ══════════════════════════════════════
function drawTerrain(){
  ctx.fillStyle='#243318'; ctx.fillRect(0,0,(COLS-PANEL_COLS)*GRID,ROWS*GRID);
  ctx.strokeStyle='rgba(70,95,38,0.25)'; ctx.lineWidth=0.5;
  for(let c=0;c<=(COLS-PANEL_COLS);c++){ctx.beginPath();ctx.moveTo(c*GRID,0);ctx.lineTo(c*GRID,ROWS*GRID);ctx.stroke();}
  for(let r=0;r<=ROWS;r++){ctx.beginPath();ctx.moveTo(0,r*GRID);ctx.lineTo((COLS-PANEL_COLS)*GRID,r*GRID);ctx.stroke();}
  // path
  ctx.strokeStyle='#8B6914'; ctx.lineWidth=GRID*0.74; ctx.lineCap='round'; ctx.lineJoin='round';
  ctx.beginPath(); ctx.moveTo(pathPoints[0].x,pathPoints[0].y);
  pathPoints.forEach(p=>ctx.lineTo(p.x,p.y)); ctx.stroke();
  ctx.strokeStyle='#7a5c10'; ctx.lineWidth=GRID*0.7;
  ctx.beginPath(); ctx.moveTo(pathPoints[0].x,pathPoints[0].y);
  pathPoints.forEach(p=>ctx.lineTo(p.x,p.y)); ctx.stroke();
  ctx.setLineDash([]); ctx.lineCap='butt';
  // decorative trees
  [[1,5],[2,11],[6,3],[9,5],[10,12],[14,3],[15,9],[17,2]].forEach(([gx,gy])=>{
    if(!isCellOccupied(gx,gy)){
      ctx.fillStyle='#1e4a12';
      ctx.beginPath(); ctx.arc(gx*GRID+GRID*.5,gy*GRID+GRID*.5,GRID*.22,0,Math.PI*2); ctx.fill();
    }
  });
}
 
function drawCastle(){
  const px=(COLS-PANEL_COLS)*GRID;
  ctx.fillStyle='#100805'; ctx.fillRect(px,0,PANEL_COLS*GRID,ROWS*GRID);
  const cx=px+10, cy=50, cw=PANEL_COLS*GRID-20, ch=ROWS*GRID-80;
  ctx.fillStyle='#6a5a4a'; ctx.strokeStyle='#9a8a6a'; ctx.lineWidth=2;
  ctx.beginPath(); ctx.roundRect(cx,cy,cw,ch,5); ctx.fill(); ctx.stroke();
  ctx.fillStyle='#7a6a5a';
  ctx.fillRect(cx-8,cy+20,24,ch*.4); ctx.fillRect(cx+cw-16,cy+20,24,ch*.4);
  ctx.fillStyle='#3a2a1a';
  ctx.beginPath(); ctx.arc(cx+cw/2,cy+ch*.42,GRID*.6,Math.PI,0,false);
  ctx.rect(cx+cw/2-GRID*.6,cy+ch*.42,GRID*1.2,GRID*.8); ctx.fill();
  ctx.fillStyle='#8a7a6a';
  for(let i=0;i<5;i++){ctx.fillRect(cx+i*cw*.22,cy-8,cw*.14,14);}
  const hp=gameState.lives/20;
  ctx.fillStyle='rgba(0,0,0,.5)'; ctx.fillRect(cx,cy-22,cw,10);
  ctx.fillStyle=hp>.5?'#60c040':hp>.25?'#e0a020':'#e04020';
  ctx.fillRect(cx,cy-22,cw*hp,10);
  ctx.strokeStyle='#9a8a6a'; ctx.lineWidth=1; ctx.strokeRect(cx,cy-22,cw,10);
}
 
// ══════════════════════════════════════
// INPUT & TOWER PLACEMENT
// ══════════════════════════════════════
let hoveredCell=null;
canvas.addEventListener('mousemove',e=>{
  const r=canvas.getBoundingClientRect();
  hoveredCell={gx:Math.floor((e.clientX-r.left)/GRID),gy:Math.floor((e.clientY-r.top)/GRID)};
});
canvas.addEventListener('mouseleave',()=>hoveredCell=null);
canvas.addEventListener('click',e=>{
  const r=canvas.getBoundingClientRect();
  const gx=Math.floor((e.clientX-r.left)/GRID), gy=Math.floor((e.clientY-r.top)/GRID);
  if(gameState.selectedType){ placeTower(gx,gy); }
  else {
    const t=towers.find(t=>t.gx===gx&&t.gy===gy);
    if(t) selectExistingTower(t);
    else { gameState.selectedTower=null; updateSelectedInfo(); }
  }
});
 
function placeTower(gx,gy){
  if(gx>=(COLS-PANEL_COLS)||gy>=ROWS||gy<0) return;
  if(isCellOccupied(gx,gy)) return;
  const def=TOWER_DEFS[gameState.selectedType];
  if(gameState.gold<def.cost) return;
  gameState.gold-=def.cost;
  towers.push({
    type:gameState.selectedType, gx, gy,
    x:gx*GRID+GRID/2, y:gy*GRID+GRID/2,
    level:0, cooldown:0,
    range:def.range, fireRate:def.fireRate, damage:def.damage,
    projSpeed:def.projSpeed, splash:def.splash||0, slow:def.slow||0,
    burn:def.burn||false, pierce:def.pierce||false, chain:def.chain||0,
    projType:def.projType
  });
  updateUI();
}
 
function selectExistingTower(t){
  gameState.selectedTower=t; gameState.selectedType=null;
  Object.keys(TOWER_DEFS).forEach(k=>document.getElementById('btn-'+k).classList.remove('selected'));
  updateSelectedInfo();
}
 
function selectTower(type){
  if(gameState.selectedTower){gameState.selectedTower=null;updateSelectedInfo();}
  if(gameState.selectedType===type){gameState.selectedType=null;document.getElementById('btn-'+type).classList.remove('selected');return;}
  gameState.selectedType=type;
  Object.keys(TOWER_DEFS).forEach(k=>document.getElementById('btn-'+k).classList.remove('selected'));
  document.getElementById('btn-'+type).classList.add('selected');
}
 
function upgradeTower(){
  const t=gameState.selectedTower; if(!t||t.level>=2) return;
  const def=TOWER_DEFS[t.type];
  const cost=def.upgradeCost[t.level];
  if(gameState.gold<cost) return;
  gameState.gold-=cost; t.level++;
  if(t.type==='archer'){t.damage+=t.level===1?12:22;t.range+=t.level===1?18:0;t.fireRate+=t.level===2?.6:0;}
  if(t.type==='cannon'){t.damage+=t.level===1?35:55;t.splash+=t.level===1?15:0;t.fireRate+=t.level===2?.25:0;}
  if(t.type==='magic'){t.damage+=t.level===1?22:0;t.slow=Math.min((t.slow||.5)*(t.level===1?2:1),1.5);t.range+=t.level===2?30:0;t.chain=(t.level===2?1:t.chain||0);}
  if(t.type==='frost'){t.damage+=t.level===1?15:25;t.slow=Math.min((t.slow||.8)+.15,1.8);t.range+=t.level===2?20:0;}
  if(t.type==='lightning'){t.damage+=t.level===1?20:35;t.chain+=t.level===1?1:2;t.fireRate+=t.level===2?.3:0;}
  if(t.type==='ballista'){t.damage+=t.level===1?50:80;t.range+=t.level===1?25:0;t.fireRate+=t.level===2?.2:0;}
  if(t.type==='inferno'){t.damage+=t.level===1?18:30;t.splash+=t.level===1?10:0;t.fireRate+=t.level===2?.5:0;}
  spawnParticles(t.x,t.y,'#FFD700',14,4);
  updateSelectedInfo(); updateUI();
}
 
function sellTower(){
  const t=gameState.selectedTower; if(!t) return;
  const def=TOWER_DEFS[t.type];
  const refund=Math.floor((def.cost+def.upgradeCost.slice(0,t.level).reduce((a,b)=>a+b,0))*.6);
  gameState.gold+=refund;
  towers=towers.filter(tt=>tt!==t);
  gameState.selectedTower=null;
  updateSelectedInfo(); updateUI();
}
 
function updateSelectedInfo(){
  const info=document.getElementById('selected-info');
  if(!gameState.selectedTower){info.style.display='none';return;}
  info.style.display='block';
  const t=gameState.selectedTower, def=TOWER_DEFS[t.type];
  document.getElementById('sel-name').textContent=def.name;
  let s=`Dmg:${t.damage} Rng:${Math.round(t.range)}\nRate:${t.fireRate.toFixed(1)}/s Lv:${t.level}/2`;
  if(t.splash)s+=`\nSplash:${t.splash}`;
  if(t.slow)s+=`\nSlow:${Math.round(t.slow*100)}%`;
  if(t.chain)s+=`\nChain:${t.chain}`;
  if(t.burn)s+=`\nBurn:ON`;
  if(t.pierce)s+=`\nPierce:ON`;
  document.getElementById('sel-stats').style.whiteSpace='pre';
  document.getElementById('sel-stats').textContent=s;
  const ub=document.getElementById('upgrade-btn');
  if(t.level<2){ub.textContent=`⬆ UPGRADE 💰${def.upgradeCost[t.level]}`;ub.style.display='block';ub.disabled=gameState.gold<def.upgradeCost[t.level];}
  else{ub.textContent='MAX LEVEL';ub.disabled=true;}
}
 
function updateUI(){
  document.getElementById('gold-val').textContent=gameState.gold;
  document.getElementById('lives-val').textContent=gameState.lives;
  document.getElementById('score-val').textContent=gameState.score;
  Object.keys(TOWER_DEFS).forEach(k=>{document.getElementById('btn-'+k).classList.toggle('disabled',gameState.gold<TOWER_DEFS[k].cost);});
  updateSelectedInfo();
}
 
function toggleSpeed(){
  gameState.speed=gameState.speed===1?2:1;
  document.getElementById('speed-btn').textContent=gameState.speed===1?'▶▶ 2×':'▶ 1×';
}
 
// ══════════════════════════════════════
// GAME LOOP
// ══════════════════════════════════════
let lastTime=0;
function gameLoop(ts){
  const rawDt=Math.min((ts-lastTime)/1000,.05); lastTime=ts;
  const dt=rawDt*gameState.speed;
  animFrame++;
  if(!gameState.gameOver&&!gameState.victory) update(dt);
  render();
  requestAnimationFrame(gameLoop);
}
 
function update(dt){
  if(gameState.waveActive&&spawnQueue.length>0){
    spawnTimer-=dt;
    if(spawnTimer<=0){spawnEnemy(spawnQueue.shift());spawnTimer=0.32+Math.random()*0.28;}
  }
  // move enemies
  for(let i=enemies.length-1;i>=0;i--){
    const e=enemies[i];
    e.slowTimer=Math.max(0,e.slowTimer-dt);
    if(e.burnTimer>0){e.burnTimer-=dt;e.hp-=18*dt;if(e.hp<=0){killEnemy(e);continue;}}
    const spd=e.speed*(e.slowTimer>0?0.35:1);
    if(e.pathIdx>=pathPoints.length-1){
      const dmg=e.type==='boss'?4:e.type==='golem'||e.type==='drake'?3:e.type==='troll'||e.type==='werewolf'?2:1;
      gameState.lives=Math.max(0,gameState.lives-dmg);
      spawnParticles(e.x,e.y,'#ff4040',8,4);
      enemies.splice(i,1); updateUI();
      if(gameState.lives<=0){gameState.gameOver=true;showMessage('DEFEATED','The castle has fallen...');}
      continue;
    }
    const tgt=pathPoints[e.pathIdx];
    const dx=tgt.x-e.x, dy=tgt.y-e.y, dist=Math.sqrt(dx*dx+dy*dy);
    if(dist<2) e.pathIdx++;
    else{e.x+=dx/dist*spd*dt; e.y+=dy/dist*spd*dt;}
  }
  // towers fire
  towers.forEach(t=>{
    t.cooldown=Math.max(0,t.cooldown-dt);
    if(t.cooldown>0) return;
    let best=null, bestIdx=-1;
    enemies.forEach(e=>{
      const dx=e.x-t.x, dy=e.y-t.y;
      if(dx*dx+dy*dy<=t.range*t.range&&e.pathIdx>bestIdx){best=e;bestIdx=e.pathIdx;}
    });
    if(!best) return;
    t.cooldown=1/t.fireRate;
    if(t.projType==='lightning'){
      // instant hit with chain
      hitEnemy({type:'lightning',damage:t.damage,slow:0,burn:false,chain:t.chain,chainLeft:t.chain,x:t.x,y:t.y,dx:0,dy:0,speed:0,projType:'lightning'},best);
      projectiles.push({type:'lightning',x:t.x,y:t.y,dx:0,dy:0,speed:0,target:best,damage:0,ttl:0.12,projType:'lightning'});
      return;
    }
    const dx=best.x-t.x, dy=best.y-t.y, dist=Math.sqrt(dx*dx+dy*dy);
    projectiles.push({
      type:t.projType, x:t.x, y:t.y, dx:dx/dist, dy:dy/dist,
      speed:t.projSpeed, target:best,
      damage:t.damage, splash:t.splash, slow:t.slow,
      burn:t.burn||false, pierce:t.pierce||false,
      chain:t.chain||0, chainLeft:t.chain||0
    });
  });
  // move projectiles
  for(let i=projectiles.length-1;i>=0;i--){
    const p=projectiles[i];
    if(p.type==='lightning'){p.ttl-=dt;if(p.ttl<=0)projectiles.splice(i,1);continue;}
    if(p.target&&!p.splash){
      const dx=p.target.x-p.x, dy=p.target.y-p.y, dist=Math.sqrt(dx*dx+dy*dy);
      if(dist<8){hitEnemy(p,p.target);projectiles.splice(i,1);continue;}
      p.dx=dx/dist; p.dy=dy/dist;
    }
    p.x+=p.dx*p.speed*dt; p.y+=p.dy*p.speed*dt;
    if(p.splash&&p.target){
      const dx=p.target.x-p.x, dy=p.target.y-p.y;
      if(dx*dx+dy*dy<100){hitSplash(p);projectiles.splice(i,1);continue;}
    }
    if(p.x<0||p.x>1000||p.y<0||p.y>620) projectiles.splice(i,1);
  }
  // particles
  for(let i=particles.length-1;i>=0;i--){
    const p=particles[i];
    p.x+=p.dx*dt; p.y+=p.dy*dt; p.dy+=50*dt; p.life-=dt;
    if(p.life<=0) particles.splice(i,1);
  }
  // wave end
  if(gameState.waveActive&&spawnQueue.length===0&&enemies.length===0){
    gameState.waveActive=false;
    document.getElementById('start-btn').disabled=false;
    if(gameState.wave>=gameState.totalWaves){gameState.victory=true;showMessage('VICTORY!','The realm is saved!');}
    else{const b=40+gameState.wave*10;gameState.gold+=b;spawnParticles(450,300,'#FFD700',20,5);updateUI();}
  }
}
 
function hitEnemy(p,e){
  if(!enemies.includes(e)) return;
  const dmg=p.damage*(1-e.armor);
  e.hp-=dmg;
  if(p.slow) e.slowTimer=3.5;
  if(p.burn) e.burnTimer=3;
  spawnParticles(e.x,e.y,p.type==='magic'?'#c080ff':p.type==='frost'?'#a0e8ff':p.type==='lightning'?'#ffee00':p.type==='fireball'?'#ff6020':p.type==='bolt'?'#c8a050':'#DAA520',5,2);
  if(p.chainLeft>0){
    const chain=enemies.filter(en=>en!==e&&Math.hypot(en.x-e.x,en.y-e.y)<110)[0];
    if(chain){
      if(p.type==='lightning'){
        hitEnemy({...p,chainLeft:p.chainLeft-1},chain);
        projectiles.push({type:'lightning',x:e.x,y:e.y,target:chain,dx:0,dy:0,speed:0,damage:0,ttl:0.1});
      } else {
        projectiles.push({...p,x:e.x,y:e.y,target:chain,chainLeft:p.chainLeft-1,dx:0,dy:0});
      }
    }
  }
  if(p.pierce&&p.type==='bolt'){
    const next=enemies.find(en=>en!==e&&Math.hypot(en.x-p.x,en.y-p.y)<50);
    if(next) hitEnemy({...p,pierce:false},next);
  }
  if(e.hp<=0) killEnemy(e);
}
 
function hitSplash(p){
  enemies.forEach(e=>{
    const dx=e.x-p.target.x, dy=e.y-p.target.y;
    if(dx*dx+dy*dy<=(p.splash||40)*(p.splash||40)){
      e.hp-=p.damage*(1-e.armor);
      if(p.burn) e.burnTimer=3;
      if(e.hp<=0) killEnemy(e);
    }
  });
  const col=p.type==='fireball'?'#ff6020':'#6060a0';
  spawnParticles(p.target.x,p.target.y,col,12,5);
}
 
function killEnemy(e){
  if(!enemies.includes(e)) return;
  gameState.gold+=e.reward;
  gameState.score+=e.score||20;
  const col=e.type==='boss'?'#ff6060':e.type==='golem'?'#9090b0':e.type==='wraith'?'#c060ff':'#88cc44';
  spawnParticles(e.x,e.y,col,e.type==='boss'?20:12,3);
  enemies.splice(enemies.indexOf(e),1);
  updateUI();
}
 
function showMessage(title,sub){
  const o=document.getElementById('message-overlay'); o.style.display='block';
  document.getElementById('msg-title').textContent=title;
  document.getElementById('msg-sub').textContent=sub;
  if(gameState.gameOver||gameState.victory){
    document.getElementById('start-btn').textContent='⟳ PLAY AGAIN';
    document.getElementById('start-btn').disabled=false;
    document.getElementById('start-btn').onclick=()=>location.reload();
  }
}
 
function render(){
  ctx.clearRect(0,0,1000,620);
  drawTerrain(); drawCastle();
  if(hoveredCell&&gameState.selectedType&&hoveredCell.gx<COLS-PANEL_COLS){
    const {gx,gy}=hoveredCell;
    const canPlace=!isCellOccupied(gx,gy);
    const def=TOWER_DEFS[gameState.selectedType];
    const canAfford=gameState.gold>=def.cost;
    ctx.fillStyle=canPlace&&canAfford?'rgba(100,200,100,0.18)':'rgba(200,60,60,0.18)';
    ctx.strokeStyle=canPlace&&canAfford?'rgba(100,200,100,0.55)':'rgba(200,60,60,0.55)';
    ctx.lineWidth=1; ctx.fillRect(gx*GRID,gy*GRID,GRID,GRID); ctx.strokeRect(gx*GRID,gy*GRID,GRID,GRID);
    if(canPlace&&canAfford){
      ctx.strokeStyle='rgba(200,200,100,0.18)'; ctx.lineWidth=1; ctx.setLineDash([4,4]);
      ctx.beginPath(); ctx.arc(gx*GRID+GRID/2,gy*GRID+GRID/2,def.range,0,Math.PI*2); ctx.stroke();
      ctx.setLineDash([]);
    }
  }
  if(gameState.selectedTower){
    const t=gameState.selectedTower;
    ctx.strokeStyle='rgba(200,200,100,0.22)'; ctx.lineWidth=1; ctx.setLineDash([4,4]);
    ctx.beginPath(); ctx.arc(t.x,t.y,t.range,0,Math.PI*2); ctx.stroke();
    ctx.setLineDash([]);
    ctx.strokeStyle='rgba(240,200,60,0.65)'; ctx.lineWidth=1.5;
    ctx.strokeRect(t.gx*GRID,t.gy*GRID,GRID,GRID);
  }
  towers.forEach(t=>TOWER_DEFS[t.type].draw(ctx,t.x,t.y,t.level,false));
  enemies.forEach(e=>drawEnemy(e));
  projectiles.forEach(p=>drawProjectile(p));
  particles.forEach(p=>drawParticle(p));
  ctx.fillStyle='rgba(0,0,0,0.04)';
  for(let y=0;y<620;y+=3) ctx.fillRect(0,y,1000,1);
  const vg=ctx.createRadialGradient(500,310,220,500,310,510);
  vg.addColorStop(0,'rgba(0,0,0,0)'); vg.addColorStop(1,'rgba(0,0,0,0.45)');
  ctx.fillStyle=vg; ctx.fillRect(0,0,1000,620);
}
 
// draw previews
function drawPreviews(){
  Object.keys(TOWER_DEFS).forEach(type=>{
    const c=document.getElementById('preview-'+type);
    if(!c) return;
    const cx=c.getContext('2d'); cx.clearRect(0,0,40,40);
    TOWER_DEFS[type].draw(cx,20,22,0,true);
  });
}
drawPreviews();
updateUI();
requestAnimationFrame(t=>{lastTime=t;requestAnimationFrame(gameLoop);});
</script>
